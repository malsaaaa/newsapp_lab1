# News App Backend - Environment Configuration

# Server Configuration
PORT=3000
NODE_ENV=development

# MongoDB Connection
# For local MongoDB: mongodb://localhost:27017/news_app
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/news_app?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/news_app

# API Configuration
MAX_PAGE_SIZE=100
DEFAULT_PAGE_SIZE=20

# NewsAPI Configuration
NEWSAPI_KEY=06c35b644d90456d9c3ffb64dca6c39b
NEWSAPI_BASE_URL=https://newsapi.org/v2
NEWSAPI_COUNTRY=us
NEWSAPI_SYNC_INTERVAL=3600

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production-2026

# Feature Flags
ENABLE_DEBUG_LOGS=true
ENABLE_SAMPLE_DATA=true

# CORS Configuration
CORS_ORIGIN=*

# News Data Configuration
NEWS_CACHE_DURATION=3600
ARTICLES_PER_FETCH=50

# Rate Limiting (optional)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
